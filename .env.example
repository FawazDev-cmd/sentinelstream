# Safe local Docker Compose defaults; replace for non-local environments.
POSTGRES_DB=sentinelstream_local
POSTGRES_USER=sentinelstream
POSTGRES_PASSWORD=sentinelstream_local_password
POSTGRES_PORT=5432
API_PORT=8000

SENTINELSTREAM_APPLICATION_NAME=SentinelStream
SENTINELSTREAM_APPLICATION_VERSION=0.1.0
SENTINELSTREAM_ENVIRONMENT=local
SENTINELSTREAM_LOG_LEVEL=INFO
SENTINELSTREAM_JSON_LOGGING_ENABLED=true
SENTINELSTREAM_EVENT_QUEUE_MAX_SIZE=1000
SENTINELSTREAM_WORKER_SHUTDOWN_TIMEOUT_SECONDS=10
SENTINELSTREAM_INCIDENT_GENERATION_LOOKBACK_SECONDS=3600
SENTINELSTREAM_DATABASE_URL=postgresql+asyncpg://sentinelstream:sentinelstream_local_password@postgres:5432/sentinelstream_local
SENTINELSTREAM_DATABASE_ECHO=false
